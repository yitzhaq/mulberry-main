#
# Top Level Makefile for Mulberry
#
# Compatibility: GNU
#
# $Date$
# $Revision$
#

.PHONY: all clean distclean install uninstall archive timezones emoji-table

OS_NAME = @OS_NAME@
PROC_NAME = @PROC_NAME@
REL_NAME = @REL_NAME@
RELEASE_DIR = $(OS_NAME)-$(PROC_NAME)-$(REL_NAME)
ARCHIVE_NAME = mulberry-$(MUL_VERSION)-$(ARCHIVE_SUFFIX)
INSTALL = @INSTALL@
PWD := $(shell pwd)

include Build/make.version
include Build/make.local

all: timezones emoji-table
	(cd Linux; ./links.sh)
	$(MAKE) -C Libraries $@
	$(MAKE) -C Plug-ins $@
	$(MAKE) -C Linux $@

emoji-table:
	@if [ ! -f Sources_Common/i18n/Charsets/CEmojiTable.h ]; then \
		if [ -f /usr/share/unicode/cldr/common/annotations/en.xml ]; then \
			echo "Generating emoji text substitution table..."; \
			python3 scripts/generate-emoji-table.py \
				/usr/share/unicode/cldr/common/annotations/en.xml \
				Sources_Common/i18n/Charsets/CEmojiTable.h; \
		else \
			echo "CLDR annotations not found, generating empty emoji table"; \
			printf '#ifndef __CEMOJITABLE__MULBERRY__\n#define __CEMOJITABLE__MULBERRY__\n#include <stdint.h>\n#include <stddef.h>\nstruct SEmojiEntry { const uint32_t* codepoints; uint8_t length; const char* name; };\nstatic const SEmojiEntry cEmojiTable[] = { { NULL, 0, NULL } };\nstatic const size_t cEmojiTableSize = 0;\n#endif\n' \
				> Sources_Common/i18n/Charsets/CEmojiTable.h; \
		fi; \
	fi

timezones:
	@if [ ! -d Sources_Common/Timezones/zoneinfo ] || \
	    [ -z "$$(ls Sources_Common/Timezones/zoneinfo/*.ics 2>/dev/null)" ]; then \
		echo "Generating timezone database..."; \
		./scripts/update-timezones.sh || \
		echo "WARNING: timezone generation failed (network unavailable?), continuing without timezone data"; \
	fi

install: all
	$(MAKE) -C Linux $@
	$(MAKE) -C Plug-ins $@
	$(MAKE) -C Build $@
	$(MAKE) -C Sources_Common $@

uninstall:
	$(MAKE) -C Sources_Common $@
	$(MAKE) -C Build $@
	$(MAKE) -C Plug-ins $@
	$(MAKE) -C Linux $@

distclean:
	$(MAKE) -C Linux $@
	$(MAKE) -C Plug-ins $@
	$(MAKE) -C Libraries $@
	rm -rf Linux/Includes/*
	find Sources_Common/Timezones/zoneinfo -name '*.ics' -delete 2>/dev/null; rm -f Sources_Common/Timezones/zoneinfo/version.txt Sources_Common/Timezones/zoneinfo/zones.h Sources_Common/Timezones/zoneinfo/zones.tab
	rm -f Sources_Common/i18n/Charsets/CEmojiTable.h

clean:
	$(MAKE) -C Linux $@
	$(MAKE) -C Plug-ins $@
	$(MAKE) -C Libraries $@
	rm -rf Linux/Includes/*

archive:
	rm -rf Build/$(RELEASE_DIR)
	$(MAKE) BINDIR="$(PWD)/Build/$(RELEASE_DIR)" HELPDIR="$(PWD)/Build/$(RELEASE_DIR)/.mulberry" LIBDIR="$(PWD)/Build/$(RELEASE_DIR)/.mulberry" install
	cd Build/$(RELEASE_DIR) ; tar cvf $(ARCHIVE_NAME).tar mulberry .mulberry && gzip $(ARCHIVE_NAME).tar
