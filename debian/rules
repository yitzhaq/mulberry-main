#!/usr/bin/make -f
#
# Debian build file for Mulberry
#
# Original: 2009 by Martin Dietze
# Modernized: 2026 using debhelper 13

# Enable full hardening, LTO optimization, and QA checks
# - hardening=+all,+bindnow: All security hardening including immediate binding
# - optimize=+lto: Link-time optimization for better performance
# - qa=+bug: Treat problematic code patterns as errors
export DEB_BUILD_MAINT_OPTIONS = hardening=+all,+bindnow optimize=+lto qa=+bug

# JX library paths
JXDIST := $(CURDIR)/Libraries/JX/dist

%:
	dh $@

override_dh_auto_configure:
	# Generate current timezone data from IANA tzdata
	./scripts/update-timezones.sh
	# Run autoconf to generate configure script
	autoconf
	# Configure with custom paths
	dh_auto_configure -- \
		--prefix=/usr \
		--with-mulberry-dir=lib/mulberry \
		--with-help-dir=share/doc/mulberry \
		--with-program-dir=bin

override_dh_auto_build:
	# Create JX distribution directories
	mkdir -p $(JXDIST)/lib $(JXDIST)/bin Linux/Includes
	# Build with custom JX paths, skip bundled OpenSSL
	JX_INSTALL_ROOT="$(JXDIST)/bin" \
	JX_LIB_ROOT="$(JXDIST)/lib" \
	ROOT_DATA_FILE_DIR="$(JXDIST)/data" \
		dh_auto_build -- SKIPOPENSSL="yes"

override_dh_auto_install:
	# Install with custom JX paths, skip JX reinstall
	JX_INSTALL_ROOT="$(JXDIST)/bin" \
	JX_LIB_ROOT="$(JXDIST)/lib" \
		dh_auto_install -- SKIPOPENSSL="yes" SKIPJX="yes"
	# Fix permissions on non-executable resource files
	chmod 644 $(CURDIR)/debian/mulberry/usr/lib/mulberry/Resources/*
	chmod 644 $(CURDIR)/debian/mulberry/usr/lib/mulberry/icons/*.xpm

override_dh_auto_clean:
	# Clean timezone generated files
	rm -f Sources_Common/Timezones/zoneinfo/*.ics \
	      Sources_Common/Timezones/zoneinfo/*/*.ics \
	      Sources_Common/Timezones/zoneinfo/version.txt
	# Clean JX distribution and build artifacts
	rm -rf $(JXDIST)/lib Linux/Includes
	# Run standard clean (ignore errors from bundled openssl which we don't build)
	-dh_auto_clean
